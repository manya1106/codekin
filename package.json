{
  "name": "codekin-companion",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "npm run dev -w @codekin/web",
    "dev:web": "npm run dev -w @codekin/web",
    "dev:extension": "npm run dev -w @codekin/extension",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": { "node": ">=20" }
}
